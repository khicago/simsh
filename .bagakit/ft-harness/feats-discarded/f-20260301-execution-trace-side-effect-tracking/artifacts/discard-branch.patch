+	}
+	if ceiling.Timeout > 0 && requested.Timeout > ceiling.Timeout {
+		return fmt.Errorf("%w: requested timeout %s exceeds session ceiling %s", ErrPolicyCeilingExceeded, requested.Timeout, ceiling.Timeout)
+	}
