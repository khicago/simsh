+}
+
+func funcValueIdentity(fn any) uintptr {
+	return interfaceIdentity(fn)
+}
+
+func interfaceIdentity(v any) uintptr {
+	if v == nil {
+		return 0
+	}
+	type eface struct {
+		typ  unsafe.Pointer
+		data unsafe.Pointer
+	}
+	return uintptr((*eface)(unsafe.Pointer(&v)).data)
+}
