+func writeModeRank(mode WriteMode) int {
+	switch mode {
+	case WriteModeDisabled:
+		return 0
+	case WriteModeReadOnly:
+		return 1
+	case WriteModeWriteLimited:
+		return 2
+	case WriteModeFull:
+		return 3
+	default:
+		return 1
+	}
+}
